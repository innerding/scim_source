# Cloudflare Worker URL — nach `wrangler deploy` erhalten
# Format: https://scim3-bundle-worker.DEIN_ACCOUNT.workers.dev
VITE_WORKER_URL=https://scim3-bundle-worker.YOUR_ACCOUNT.workers.dev

# API-Key — muss identisch mit dem Wrangler-Secret UPLOAD_API_KEY sein
# Setzen per: wrangler secret put UPLOAD_API_KEY (im worker/-Verzeichnis)
VITE_UPLOAD_API_KEY=REPLACE_WITH_YOUR_KEY
